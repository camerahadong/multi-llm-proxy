{
  "name": "multi-llm-proxy",
  "version": "2.0.0",
  "description": "OpenAI-compatible proxy unifying Claude (OAuth), Codex (ChatGPT Plus OAuth), Gemini (Google OAuth GCA) behind one endpoint, with per-backend process pool, backpressure, and Prometheus metrics.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx scripts/bench-pool.ts",
    "migrate": "tsx scripts/migrate-from-claude-app.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/sensible": "^6.0.1",
    "fastify": "^5.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
